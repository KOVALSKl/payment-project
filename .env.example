DB_USER=your_user
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_db_name


API_KEY=your_static_api_key

# RabbitMQ: доменные сообщения (outbox → payments.new)
RABBITMQ_URL=amqp://guest:guest@localhost:5672//
PAYMENTS_NEW_QUEUE=payments.new
PAYMENTS_RETRY_QUEUE=payments.retry
PAYMENTS_DLQ_QUEUE=payments.dlq
WEBHOOK_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_SECONDS=5

# Celery (брокер задач; не смешивать с очередью consumer)
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//

# Outbox publisher
OUTBOX_PUBLISH_BATCH_SIZE=100
OUTBOX_BEAT_INTERVAL_SECONDS=15
